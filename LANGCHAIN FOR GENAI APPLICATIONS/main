### B3. Persistent Conversational Interface with ConversationSummaryBufferMemory

> Build a FastAPI chatbot that remembers conversation history while saving tokens.

#### Full Chatbot Code

```python
# ============================================================
# FastAPI Chatbot with Persistent Summary Memory
# ============================================================

# --- Import required libraries ---
from fastapi import FastAPI
from pydantic import BaseModel
from langchain_openai import ChatOpenAI
from langchain.memory import ConversationSummaryBufferMemory
from langchain.chains import ConversationChain
import os

# --- Step 1: Set up API key ---
os.environ["OPENAI_API_KEY"] = "your-openai-api-key-here"

# --- Step 2: Create FastAPI app ---
app = FastAPI(title="Smart Chatbot with Memory")

# --- Step 3: Create the LLM ---
llm = ChatOpenAI(model="gpt-3.5-turbo", temperature=0.7)

# --- Step 4: Set up ConversationSummaryBufferMemory ---
# This memory type does two things:
#   1. Keeps recent messages as-is (buffer)
#   2. Summarizes older messages to save tokens
# max_token_limit = when buffer exceeds this, older messages get summarized
memory = ConversationSummaryBufferMemory(
    llm=llm,
    max_token_limit=300,       # Summarize when buffer exceeds 300 tokens
    return_messages=True        # Return as message objects
)

# --- Step 5: Create the conversation chain ---
conversation = ConversationChain(
    llm=llm,
    memory=memory,
    verbose=True   # Show what's happening behind the scenes
)

# --- Step 6: Define request/response models ---
class ChatRequest(BaseModel):
    """What the user sends to the chatbot"""
    message: str

class ChatResponse(BaseModel):
    """What the chatbot sends back"""
    reply: str
    memory_summary: str

# --- Step 7: Create the chat endpoint ---
@app.post("/chat", response_model=ChatResponse)
def chat(request: ChatRequest):
    """
    Send a message and get a reply.
    The chatbot remembers previous messages using summary memory.
    """
    # Get the chatbot's response
    response = conversation.predict(input=request.message)

    # Get the current memory summary (for debugging/display)
    current_summary = memory.moving_summary_buffer

    return ChatResponse(
        reply=response,
        memory_summary=current_summary if current_summary else "No summary yet (recent messages still in buffer)"
    )

# --- Step 8: Endpoint to view memory status ---
@app.get("/memory")
def get_memory():
    """Check what the chatbot currently remembers"""
    return {
        "summary": memory.moving_summary_buffer,
        "buffer": [str(msg) for msg in memory.buffer]
    }

# --- Step 9: Endpoint to clear memory ---
@app.post("/clear")
def clear_memory():
    """Reset the chatbot's memory"""
    memory.clear()
    return {"message": "Memory cleared!"}

# --- Step 10: Run the server ---
if __name__ == "__main__":
    import uvicorn
    uvicorn.run(app, host="0.0.0.0", port=8000)
```

