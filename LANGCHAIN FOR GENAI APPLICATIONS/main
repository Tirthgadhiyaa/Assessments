### B1. RAG Pipeline using LangChain's PyPDFLoader and ChromaDB

> Build a Retrieval-Augmented Generation (RAG) pipeline to perform semantic searches over corporate policy documents.

#### Step 2 — Full RAG Pipeline Code

```python
# ============================================================
# RAG Pipeline: Semantic Search over Corporate Policy PDFs
# ============================================================

# --- Import required libraries ---
from langchain_community.document_loaders import PyPDFLoader
from langchain.text_splitter import RecursiveCharacterTextSplitter
from langchain_community.vectorstores import Chroma
from langchain_openai import OpenAIEmbeddings, ChatOpenAI
from langchain.chains import RetrievalQA
import os

# --- Step 1: Set up your API key ---
os.environ["OPENAI_API_KEY"] = "openai-api-key-here"

# --- Step 2: Load the PDF document ---
# PyPDFLoader reads each page of the PDF as a separate document
loader = PyPDFLoader("corporate_policy.pdf")
pages = loader.load()

print(f"Total pages loaded: {len(pages)}")

# --- Step 3: Split the document into smaller chunks ---
# We split because LLMs have a token limit and smaller chunks
# give more precise search results
text_splitter = RecursiveCharacterTextSplitter(
    chunk_size=500,         # Each chunk will have at most 500 characters
    chunk_overlap=50        # 50 characters overlap between chunks for context
)
chunks = text_splitter.split_documents(pages)

print(f"Total chunks created: {len(chunks)}")

# --- Step 4: Create embeddings and store in ChromaDB ---
# Embeddings convert text into numerical vectors for similarity search
embeddings = OpenAIEmbeddings()

# ChromaDB stores these vectors locally for fast retrieval
vector_store = Chroma.from_documents(
    documents=chunks,
    embedding=embeddings,
    persist_directory="./chroma_db"   # Save the database locally
)

print("Vector store created and saved!")

# --- Step 5: Create a retriever ---
# The retriever will find the top 3 most relevant chunks for any query
retriever = vector_store.as_retriever(
    search_type="similarity",
    search_kwargs={"k": 3}    # Return top 3 matching chunks
)

# --- Step 6: Create the RAG chain ---
# This chain combines retrieval (finding relevant docs) with generation (LLM answer)
llm = ChatOpenAI(model="gpt-3.5-turbo", temperature=0)

qa_chain = RetrievalQA.from_chain_type(
    llm=llm,
    chain_type="stuff",         # "stuff" = put all retrieved docs into one prompt
    retriever=retriever,
    return_source_documents=True  # Also return which documents were used
)

# --- Step 7: Ask a question ---
query = "What is the company's leave policy for new employees?"
result = qa_chain.invoke({"query": query})

# --- Step 8: Display the answer ---
print("\n--- ANSWER ---")
print(result["result"])

print("\n--- SOURCE DOCUMENTS ---")
for i, doc in enumerate(result["source_documents"]):
    print(f"\nSource {i+1} (Page {doc.metadata.get('page', 'N/A')}):")
    print(doc.page_content[:200])  # Show first 200 chars of each source
```

