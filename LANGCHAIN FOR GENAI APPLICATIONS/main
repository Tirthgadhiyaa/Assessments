#### 8. Streamlit Frontend (`app.py`)

```python
# ============================================================
# app.py
# Streamlit Frontend for the Enterprise Intelligence Orchestrator
# ============================================================

import streamlit as st
from orchestrator import route_query
import time

# --- Page Configuration ---
st.set_page_config(
    page_title="Enterprise Intelligence Orchestrator",
    page_icon="",
    layout="wide"
)

# --- Title and Description ---
st.title(" Omni-Channel Enterprise Intelligence Orchestrator")
st.markdown(
    "Ask any question! The system automatically routes your query to:\n"
    "- ** HR Knowledge Base** — for internal policy questions\n"
    "- ** Market Analysis Agent** — for business and market queries"
)

st.divider()

# --- Sidebar ---
st.sidebar.header("About")
st.sidebar.info(
    "This system uses LangChain to:\n"
    "1. Classify your query (HR or Market)\n"
    "2. Route to the right AI module\n"
    "3. Return an accurate answer"
)

# --- Chat History ---
if "chat_history" not in st.session_state:
    st.session_state.chat_history = []

# --- User Input ---
user_query = st.text_input(
    " Ask your question:",
    placeholder="e.g., What is our work-from-home policy?"
)

# --- Process Query ---
if st.button(" Get Answer", type="primary"):
    if user_query.strip():

        # Show a spinner while processing
        with st.spinner("Thinking..."):
            result = route_query(user_query)

        # Display results
        col1, col2 = st.columns([3, 1])

        with col1:
            st.subheader(" Answer")
            st.write(result["answer"])

        with col2:
            st.subheader("Info")
            # Show which module handled the query
            if result["category"] == "HR":
                st.success(" Routed to: HR Knowledge Base")
            else:
                st.info(" Routed to: Market Analysis Agent")

            st.metric(" Response Time", f"{result['latency_seconds']}s")

        # Save to chat history
        st.session_state.chat_history.append({
            "query": user_query,
            "answer": result["answer"],
            "category": result["category"],
            "latency": result["latency_seconds"]
        })
    else:
        st.warning("Please enter a question!")

# --- Display Chat History ---
if st.session_state.chat_history:
    st.divider()
    st.subheader(" Chat History")

    for i, chat in enumerate(reversed(st.session_state.chat_history)):
        with st.expander(f"Q: {chat['query']}", expanded=(i == 0)):
            st.write(f"**Answer:** {chat['answer']}")
            st.caption(
                f"Category: {chat['category']} | "
                f"Latency: {chat['latency']}s"
            )
```



---

#### 9. Evaluation Report (`evaluation.py`)

```python
# ============================================================
# evaluation.py
# Measures system latency and accuracy
# ============================================================

from orchestrator import route_query, classify_query
import time

# --- Test Queries with Expected Categories ---
test_cases = [
    # (query, expected_category)
    ("What is the company's annual leave policy?", "HR"),
    ("How many sick days do employees get?", "HR"),
    ("What is the dress code policy?", "HR"),
    ("Tell me about the onboarding process for new hires.", "HR"),
    ("What are the latest trends in the AI market?", "MARKET"),
    ("Who are the top competitors of Tesla?", "MARKET"),
    ("What is the current stock price of Apple?", "MARKET"),
    ("Analyze the growth of cloud computing industry.", "MARKET"),
]


def run_evaluation():
    """Run all test cases and generate a report"""

    print("=" * 60)
    print("  SYSTEM EVALUATION REPORT")
    print("=" * 60)

    correct = 0
    total = len(test_cases)
    latencies = []

    for i, (query, expected) in enumerate(test_cases):
        print(f"\nTest {i+1}/{total}: {query[:50]}...")

        # Measure classification accuracy
        start = time.time()
        predicted = classify_query(query)
        latency = round(time.time() - start, 2)
        latencies.append(latency)

        is_correct = predicted == expected
        if is_correct:
            correct += 1

        status = "✅" if is_correct else "❌"
        print(f"  Expected: {expected} | Predicted: {predicted} | {status}")
        print(f"  Latency: {latency}s")

    # --- Summary ---
    accuracy = round((correct / total) * 100, 1)
    avg_latency = round(sum(latencies) / len(latencies), 2)
    max_latency = max(latencies)
    min_latency = min(latencies)

    print("\n" + "=" * 60)
    print("  SUMMARY")
    print("=" * 60)
    print(f"  Total Test Cases    : {total}")
    print(f"  Correct Predictions : {correct}")
    print(f"  Accuracy            : {accuracy}%")
    print(f"  Avg Latency         : {avg_latency}s")
    print(f"  Min Latency         : {min_latency}s")
    print(f"  Max Latency         : {max_latency}s")
    print("=" * 60)


if __name__ == "__main__":
    run_evaluation()
```



