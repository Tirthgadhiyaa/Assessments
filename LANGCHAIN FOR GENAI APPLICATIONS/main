#### 5. HR Knowledge Chain (`hr_chain.py`)

```python
# ============================================================
# hr_chain.py
# Handles HR-related queries using the FAISS vector store
# ============================================================

from langchain_openai import OpenAIEmbeddings, ChatOpenAI
from langchain_community.vectorstores import FAISS
from langchain.chains import RetrievalQA
import os

os.environ["OPENAI_API_KEY"] = "your-openai-api-key-here"


def get_hr_chain(index_path: str = "./faiss_index"):
    """
    Create a retrieval chain for answering HR questions.

    Args:
        index_path: Path to the saved FAISS index

    Returns:
        A RetrievalQA chain ready to answer HR queries
    """

    # Step 1: Load the saved FAISS index
    embeddings = OpenAIEmbeddings()
    vector_store = FAISS.load_local(
        index_path,
        embeddings,
        allow_dangerous_deserialization=True
    )

    # Step 2: Create a retriever (finds top 3 relevant chunks)
    retriever = vector_store.as_retriever(
        search_kwargs={"k": 3}
    )

    # Step 3: Create the QA chain
    llm = ChatOpenAI(model="gpt-3.5-turbo", temperature=0)
    hr_chain = RetrievalQA.from_chain_type(
        llm=llm,
        chain_type="stuff",
        retriever=retriever,
        return_source_documents=True
    )

    return hr_chain


def ask_hr_question(query: str) -> str:
    """Ask an HR-related question and get an answer"""
    chain = get_hr_chain()
    result = chain.invoke({"query": query})
    return result["result"]
```

