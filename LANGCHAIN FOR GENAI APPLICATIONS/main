#### 7. Main Orchestrator — Query Router (`orchestrator.py`)

```python
# ============================================================
# orchestrator.py
# Routes queries to the right module (HR or Market Analysis)
# ============================================================

from langchain_openai import ChatOpenAI
from langchain.prompts import PromptTemplate
from hr_chain import ask_hr_question
from market_agent import ask_market_question
import time
import os

os.environ["OPENAI_API_KEY"] = "your-openai-api-key-here"


def classify_query(query: str) -> str:
    """
    Use the LLM to classify whether a query is about HR or Market.

    Args:
        query: The user's question

    Returns:
        "HR" or "MARKET"
    """

    llm = ChatOpenAI(model="gpt-3.5-turbo", temperature=0)

    # Simple classification prompt
    prompt = PromptTemplate(
        template=(
            "Classify the following query into one of two categories:\n"
            "- HR: Questions about company policies, leave, salary, "
            "  employee benefits, onboarding, workplace rules, etc.\n"
            "- MARKET: Questions about market trends, competitors, "
            "  business news, stock prices, industry analysis, etc.\n\n"
            "Query: {query}\n\n"
            "Reply with ONLY one word: HR or MARKET"
        ),
        input_variables=["query"]
    )

    # Get the classification
    response = llm.invoke(prompt.format(query=query))
    category = response.content.strip().upper()

    # Default to MARKET if unclear
    if "HR" in category:
        return "HR"
    else:
        return "MARKET"


def route_query(query: str) -> dict:
    """
    Route the query to the appropriate module and return the answer.

    Args:
        query: The user's question

    Returns:
        A dictionary with the category, answer, and time taken
    """

    # Measure how long it takes
    start_time = time.time()

    # Step 1: Classify the query
    category = classify_query(query)
    print(f"Query classified as: {category}")

    # Step 2: Route to the right module
    if category == "HR":
        answer = ask_hr_question(query)
    else:
        answer = ask_market_question(query)

    # Step 3: Calculate time taken
    end_time = time.time()
    latency = round(end_time - start_time, 2)

    return {
        "category": category,
        "answer": answer,
        "latency_seconds": latency
    }


# Quick test
if __name__ == "__main__":
    # Test HR query
    result1 = route_query("What is the maternity leave policy?")
    print(f"\nCategory: {result1['category']}")
    print(f"Answer: {result1['answer']}")
    print(f"Time: {result1['latency_seconds']}s")

    print("\n" + "="*50 + "\n")

    # Test Market query
    result2 = route_query("What are the latest trends in AI industry?")
    print(f"\nCategory: {result2['category']}")
    print(f"Answer: {result2['answer']}")
    print(f"Time: {result2['latency_seconds']}s")
```

