### B4. Self-Correction Chain with OutputFixingParser and PydanticOutputParser

> Ensure LLM-generated marketing content follows a strict JSON schema.

#### Full Self-Correction Code

```python
# ============================================================
# Self-Correction Chain: Marketing Content with JSON Schema
# ============================================================

# --- Import required libraries ---
from langchain_openai import ChatOpenAI
from langchain.output_parsers import PydanticOutputParser
from langchain.output_parsers import OutputFixingParser
from langchain.prompts import PromptTemplate
from pydantic import BaseModel, Field
from typing import List
import os

# --- Step 1: Set up API key ---
os.environ["OPENAI_API_KEY"] = "your-openai-api-key-here"

# --- Step 2: Define the JSON schema using Pydantic ---
# This is the exact structure we want the LLM to follow
class MarketingContent(BaseModel):
    """Schema for marketing content that the LLM must follow"""

    product_name: str = Field(
        description="Name of the product being marketed"
    )
    tagline: str = Field(
        description="A catchy one-line tagline for the product"
    )
    description: str = Field(
        description="A short marketing description (2-3 sentences)"
    )
    target_audience: str = Field(
        description="Who this product is aimed at"
    )
    key_features: List[str] = Field(
        description="List of 3-5 key features of the product"
    )
    call_to_action: str = Field(
        description="A compelling call-to-action sentence"
    )

# --- Step 3: Create the Pydantic output parser ---
# This parser knows the exact schema and validates LLM output against it
pydantic_parser = PydanticOutputParser(pydantic_object=MarketingContent)

# --- Step 4: Create the LLM ---
llm = ChatOpenAI(model="gpt-3.5-turbo", temperature=0.7)

# --- Step 5: Create the OutputFixingParser (Self-Correction Layer) ---
# If the LLM's output doesn't match the schema, this parser
# automatically sends the error back to the LLM and asks it to fix it
fixing_parser = OutputFixingParser.from_llm(
    parser=pydantic_parser,
    llm=llm
)

# --- Step 6: Create the prompt template ---
# We include format instructions so the LLM knows exactly what JSON to produce
prompt = PromptTemplate(
    template=(
        "You are a marketing content creator.\n"
        "Generate marketing content for the following product:\n\n"
        "Product: {product}\n\n"
        "You MUST respond in the following JSON format:\n"
        "{format_instructions}\n"
    ),
    input_variables=["product"],
    partial_variables={
        "format_instructions": pydantic_parser.get_format_instructions()
    }
)

# --- Step 7: Create and run the chain ---
def generate_marketing_content(product_name: str) -> MarketingContent:
    """
    Generate marketing content for a product.
    If the LLM gives bad output, it auto-corrects.
    """

    # Format the prompt with the product name
    formatted_prompt = prompt.format(product=product_name)

    # Get the LLM's response
    response = llm.invoke(formatted_prompt)

    # Try to parse the response — if it fails, fixing_parser will auto-correct
    try:
        # First, try the normal parser
        result = pydantic_parser.parse(response.content)
        print(" Output parsed successfully on first try!")
    except Exception as e:
        # If parsing fails, use the fixing parser to auto-correct
        print(f" First parse failed: {e}")
        print(" Auto-correcting with OutputFixingParser...")
        result = fixing_parser.parse(response.content)
        print(" Output fixed and parsed successfully!")

    return result


# --- Step 8: Test the function ---
product = "SmartFit Pro - an AI-powered fitness tracker watch"
content = generate_marketing_content(product)

# Display the result as formatted JSON
print("\n--- GENERATED MARKETING CONTENT ---")
print(f"Product Name    : {content.product_name}")
print(f"Tagline         : {content.tagline}")
print(f"Description     : {content.description}")
print(f"Target Audience : {content.target_audience}")
print(f"Key Features    : {content.key_features}")
print(f"Call to Action  : {content.call_to_action}")

# Also show as JSON
print("\n--- RAW JSON ---")
print(content.model_dump_json(indent=2))
```

#### Sample Output

```json
{
  "product_name": "SmartFit Pro",
  "tagline": "Your AI Coach, On Your Wrist",
  "description": "SmartFit Pro uses advanced AI to track your fitness goals and provide personalized workout recommendations. Stay motivated with real-time insights.",
  "target_audience": "Health-conscious adults aged 20-45 who want smart fitness tracking",
  "key_features": [
    "AI-powered workout suggestions",
    "Heart rate and sleep monitoring",
    "Waterproof design",
    "7-day battery life",
    "Syncs with all major fitness apps"
  ],
  "call_to_action": "Order your SmartFit Pro today and start your smarter fitness journey!"
}
```

