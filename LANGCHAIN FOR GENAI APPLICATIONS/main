#### 4. Vector Store Builder (`vector_store_builder.py`)

```python
# ============================================================
# vector_store_builder.py
# Builds a FAISS vector store from HR policy PDF documents
# ============================================================

from langchain_community.document_loaders import PyPDFLoader
from langchain.text_splitter import RecursiveCharacterTextSplitter
from langchain_openai import OpenAIEmbeddings
from langchain_community.vectorstores import FAISS
import os

# Set API key
os.environ["OPENAI_API_KEY"] = "your-openai-api-key-here"


def build_vector_store(pdf_path: str, save_path: str = "./faiss_index"):
    """
    Load a PDF, split it into chunks, and save as a FAISS vector store.

    Args:
        pdf_path: Path to the HR policy PDF file
        save_path: Where to save the FAISS index
    """

    # Step 1: Load the PDF
    print(f"Loading PDF: {pdf_path}")
    loader = PyPDFLoader(pdf_path)
    documents = loader.load()
    print(f"Loaded {len(documents)} pages")

    # Step 2: Split into smaller chunks
    splitter = RecursiveCharacterTextSplitter(
        chunk_size=500,
        chunk_overlap=50
    )
    chunks = splitter.split_documents(documents)
    print(f"Created {len(chunks)} chunks")

    # Step 3: Create embeddings and build FAISS index
    embeddings = OpenAIEmbeddings()
    vector_store = FAISS.from_documents(chunks, embeddings)

    # Step 4: Save the index locally
    vector_store.save_local(save_path)
    print(f"FAISS index saved to: {save_path}")

    return vector_store


# Run this script once to build the index
if __name__ == "__main__":
    build_vector_store("data/hr_policies.pdf")
```

