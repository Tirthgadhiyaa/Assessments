#### 6. Market Analysis Agent (`market_agent.py`)

```python
# ============================================================
# market_agent.py
# Handles market analysis queries using web search
# ============================================================

from langchain_openai import ChatOpenAI
from langchain.agents import initialize_agent, AgentType, Tool
from langchain_community.tools import DuckDuckGoSearchRun
from langchain.chains import LLMMathChain
import os

os.environ["OPENAI_API_KEY"] = "your-openai-api-key-here"


def get_market_agent():
    """
    Create an agent with web search and calculator tools
    for market analysis queries.

    Returns:
        An initialized agent ready for market research
    """

    llm = ChatOpenAI(model="gpt-3.5-turbo", temperature=0)

    # Tool 1: Web search for real-time market data
    search = DuckDuckGoSearchRun()
    search_tool = Tool(
        name="Market Search",
        func=search.run,
        description="Search the web for market data, business news, "
                    "competitor analysis, and industry trends."
    )

    # Tool 2: Calculator for financial calculations
    math_chain = LLMMathChain.from_llm(llm=llm)
    math_tool = Tool(
        name="Calculator",
        func=math_chain.run,
        description="Do math calculations like revenue growth, "
                    "market share percentages, etc."
    )

    # Create the agent
    agent = initialize_agent(
        tools=[search_tool, math_tool],
        llm=llm,
        agent=AgentType.ZERO_SHOT_REACT_DESCRIPTION,
        verbose=True,
        handle_parsing_errors=True
    )

    return agent


def ask_market_question(query: str) -> str:
    """Ask a market analysis question and get an answer"""
    agent = get_market_agent()
    result = agent.invoke({"input": query})
    return result["output"]
```

