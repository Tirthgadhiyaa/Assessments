# logger.py
# Module for logging all transactions to a log file

import datetime
import os


# Name of the log file
LOG_FILE = "transaction_log.txt"


def write_log(message):
    """
    Write a log entry to the log file with a timestamp.

    Parameters:
        message (str): The message to log.
    """
    try:
        # Get the current date and time
        now = datetime.datetime.now()
        timestamp = now.strftime("%Y-%m-%d %H:%M:%S")

        # Open the log file in append mode so old logs are not deleted
        with open(LOG_FILE, "a") as file:
            # Write the timestamp and message on one line
            file.write(f"[{timestamp}] {message}\n")

    except Exception as e:
        # If logging fails, print error but don't crash the program
        print(f"Warning: Could not write to log file. Error: {e}")


def view_log():
    """
    Read and display the entire log file contents.
    """
    try:
        # Check if the log file exists
        if not os.path.exists(LOG_FILE):
            print("\nNo log file found. No transactions recorded yet.")
            return

        # Open and read the log file
        with open(LOG_FILE, "r") as file:
            contents = file.read()

        # Check if the file is empty
        if contents.strip() == "":
            print("\nLog file is empty. No transactions recorded yet.")
        else:
            print("\n" + "=" * 60)
            print("          TRANSACTION LOG")
            print("=" * 60)
            print(contents)
            print("=" * 60)

    except Exception as e:
        print(f"Error reading log file: {e}")
