# storage.py
# Module for file handling — save and load stock and transactions

import json
import os


# File names for storing data
STOCK_FILE = "fruit_stock.json"
TRANSACTION_FILE = "transactions.json"


# =============================================
# STOCK FILE OPERATIONS
# =============================================

def load_stock():
    """
    Load fruit stock data from the JSON file.

    Returns:
        dict: A dictionary with fruit names as keys and
              {'price': float, 'quantity': int} as values.
              Returns empty dict if file doesn't exist.
    """
    try:
        # Check if the stock file exists
        if os.path.exists(STOCK_FILE):
            # Open and read the JSON file
            with open(STOCK_FILE, "r") as file:
                stock = json.load(file)
            return stock
        else:
            # If file does not exist, return empty dictionary
            return {}

    except Exception as e:
        print(f"Error loading stock data: {e}")
        return {}


def save_stock(stock):
    """
    Save fruit stock data to the JSON file.

    Parameters:
        stock (dict): Dictionary containing fruit stock data.
    """
    try:
        # Open the file in write mode and save the dictionary as JSON
        with open(STOCK_FILE, "w") as file:
            json.dump(stock, file, indent=4)

    except Exception as e:
        print(f"Error saving stock data: {e}")


# =============================================
# TRANSACTION FILE OPERATIONS
# =============================================

def load_transactions():
    """
    Load all transaction records from the JSON file.

    Returns:
        list: A list of transaction dictionaries.
              Returns empty list if file doesn't exist.
    """
    try:
        # Check if the transaction file exists
        if os.path.exists(TRANSACTION_FILE):
            # Open and read the JSON file
            with open(TRANSACTION_FILE, "r") as file:
                transactions = json.load(file)
            return transactions
        else:
            # If file does not exist, return empty list
            return []

    except Exception as e:
        print(f"Error loading transactions: {e}")
        return []


def save_transactions(transactions):
    """
    Save all transaction records to the JSON file.

    Parameters:
        transactions (list): List of transaction dictionaries.
    """
    try:
        # Open the file in write mode and save as JSON
        with open(TRANSACTION_FILE, "w") as file:
            json.dump(transactions, file, indent=4)

    except Exception as e:
        print(f"Error saving transactions: {e}")


def add_transaction(transaction):
    """
    Add a single transaction record to the file.

    Parameters:
        transaction (dict): A dictionary with transaction details.
    """
    # Load existing transactions
    transactions = load_transactions()

    # Add the new transaction to the list
    transactions.append(transaction)

    # Save the updated list back to the file
    save_transactions(transactions)
