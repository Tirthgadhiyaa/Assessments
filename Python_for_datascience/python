def buy_fruits():
    """
    Allow the customer to buy one or more fruits.
    Creates a transaction record and updates the stock.
    """
    try:
        print("\n--- Buy Fruits ---")

        # Load current stock from file
        stock = storage.load_stock()

        # Check if stock is empty
        if len(stock) == 0:
            print("\nNo fruits available to buy. Please check back later!")
            return

        # Get customer name
        customer_name = get_valid_string("Enter your name: ").title()

        # Dictionary to store items in this purchase (shopping cart)
        cart = {}
        total_bill = 0.0

        # Loop to allow buying multiple fruits
        while True:
            # Show available fruits
            print("\nAvailable Fruits:")
            available_fruits = []
            count = 1

            for fruit_name, details in stock.items():
                if details["quantity"] > 0:
                    print(f"  {count}. {fruit_name} - Rs.{details['price']}/kg "
                          f"(Available: {details['quantity']} kg)")
                    available_fruits.append(fruit_name)
                    count += 1

            # Check if any fruits are available
            if len(available_fruits) == 0:
                print("\nNo fruits available to buy!")
                break

            # Get fruit name from customer
            fruit_name = get_valid_string("\nEnter fruit name to buy: ").title()

            # Validate that the fruit exists and is available
            if fruit_name not in stock:
                print(f"\n'{fruit_name}' is not available in our store.")
                print("Please check the name and try again.")
                continue

            if stock[fruit_name]["quantity"] <= 0:
                print(f"\nSorry! '{fruit_name}' is out of stock.")
                continue

            # Get quantity to buy
            max_qty = stock[fruit_name]["quantity"]
            print(f"Available quantity of {fruit_name}: {max_qty} kg")

            quantity = get_valid_int(f"Enter quantity to buy (in kg): ")

            # Check if enough stock is available
            if quantity > max_qty:
                print(f"\nSorry! Only {max_qty} kg of {fruit_name} is available.")
                print("Please enter a smaller quantity.")
                continue

            # Calculate the cost for this fruit
            price = stock[fruit_name]["price"]
            cost = price * quantity

            # Add to cart
            if fruit_name in cart:
                # If same fruit bought again, add to existing quantity
                cart[fruit_name]["quantity"] += quantity
                cart[fruit_name]["cost"] += cost
            else:
                cart[fruit_name] = {
                    "price": price,
                    "quantity": quantity,
                    "cost": cost
                }

            # Update the stock (reduce quantity)
            stock[fruit_name]["quantity"] -= quantity

            # Add to total bill
            total_bill += cost

            # Show confirmation
            print(f"\nAdded {quantity} kg of {fruit_name} to cart. Cost: Rs.{cost:.2f}")

            # Ask if customer wants to buy more
            more = input("\nDo you want to buy more fruits? (yes/no): ").strip().lower()
            if more != "yes" and more != "y":
                break

        # Check if the cart is empty
        if len(cart) == 0:
            print("\nNo items purchased. Returning to Customer Menu.")
            return

        # Save the updated stock
        storage.save_stock(stock)

        # Create the transaction record (stored in dictionary)
        now = datetime.datetime.now()
        transaction = {
            "transaction_id": now.strftime("%Y%m%d%H%M%S"),
            "date": now.strftime("%Y-%m-%d"),
            "time": now.strftime("%H:%M:%S"),
            "customer_name": customer_name,
            "items": cart,
            "total_bill": total_bill
        }

        # Save transaction to file
        storage.add_transaction(transaction)

        # Log this transaction
        logger.write_log(
            f"CUSTOMER - {customer_name} purchased fruits. "
            f"Total Bill: Rs.{total_bill:.2f}"
        )

        # Display the receipt
        print("\n" + "=" * 55)
        print("            PURCHASE RECEIPT")
        print("=" * 55)
        print(f"  Transaction ID : {transaction['transaction_id']}")
        print(f"  Date           : {transaction['date']}")
        print(f"  Time           : {transaction['time']}")
        print(f"  Customer Name  : {customer_name}")
        print("-" * 55)
        print(f"  {'Fruit':<15} {'Price/kg':<12} {'Qty (kg)':<10} {'Cost (Rs)':<10}")
        print("-" * 55)

        for fruit, info in cart.items():
            print(f"  {fruit:<15} {info['price']:<12.2f} {info['quantity']:<10} "
                  f"{info['cost']:<10.2f}")

        print("-" * 55)
        print(f"  {'TOTAL BILL':>37}  Rs.{total_bill:.2f}")
        print("=" * 55)
        print("\nThank you for your purchase!")

    except Exception as e:
        print(f"\nAn error occurred: {e}")
        print("Returning to Customer Menu...")


