# Unsupervised Machine Learning
## Project: E-Commerce — Customer Segmentation by Price Sensitivity

## Setup — Install & Import Libraries
```python
import pandas as pd
import numpy as np
import matplotlib.pyplot as plt
import seaborn as sns
from sklearn.preprocessing import StandardScaler
from sklearn.cluster import KMeans, AgglomerativeClustering
from sklearn.decomposition import PCA
from sklearn.manifold import TSNE
from scipy.cluster.hierarchy import dendrogram, linkage
import warnings
warnings.filterwarnings('ignore')
```

## Task 1 — Load and Clean the Dataset (Remove NA, Duplicates)
```python
df = pd.read_csv("Customer Personality Analysis.csv", sep="\t")
print("Original shape:", df.shape)
print(df.head())
print("\nColumns:", df.columns.tolist())
print("\nMissing values:\n", df.isnull().sum())
df = df.dropna()
print("\nShape after dropping NA:", df.shape)
print("Duplicate rows:", df.duplicated().sum())
df = df.drop_duplicates()
print("Shape after dropping duplicates:", df.shape)
print("\nData types:\n", df.dtypes)
print(df.info())
```

## Task 2 — Visualize Spending Patterns and Demographics
```python
df['TotalSpending'] = (df['MntWines'] + df['MntFruits'] + df['MntMeatProducts']
                       + df['MntFishProducts'] + df['MntSweetProducts']
                       + df['MntGoldProds'])

df['Age'] = 2024 - df['Year_Birth']

plt.figure(figsize=(8, 5))
sns.histplot(df['Income'], bins=40, kde=True, color='steelblue')
plt.title('Distribution of Customer Income')
plt.xlabel('Income')
plt.ylabel('Count')
plt.tight_layout()
plt.show()

plt.figure(figsize=(8, 5))
sns.histplot(df['TotalSpending'], bins=40, kde=True, color='coral')
plt.title('Distribution of Total Spending')
plt.xlabel('Total Spending')
plt.ylabel('Count')
plt.tight_layout()
plt.show()

spending_cols = ['MntWines', 'MntFruits', 'MntMeatProducts',
                 'MntFishProducts', 'MntSweetProducts', 'MntGoldProds']

plt.figure(figsize=(10, 5))
df[spending_cols].mean().sort_values().plot(kind='barh', color='teal')
plt.title('Average Spending by Product Category')
plt.xlabel('Average Amount Spent')
plt.tight_layout()
plt.show()

plt.figure(figsize=(8, 5))
sns.histplot(df['Age'], bins=30, kde=True, color='purple')
plt.title('Age Distribution of Customers')
plt.xlabel('Age')
plt.ylabel('Count')
plt.tight_layout()
plt.show()

plt.figure(figsize=(8, 5))
sns.scatterplot(x='Income', y='TotalSpending', data=df, alpha=0.5, color='green')
plt.title('Income vs Total Spending')
plt.xlabel('Income')
plt.ylabel('Total Spending')
plt.tight_layout()
plt.show()

plt.figure(figsize=(8, 5))
df['Education'].value_counts().plot(kind='bar', color='orange')
plt.title('Customer Count by Education Level')
plt.xlabel('Education')
plt.ylabel('Count')
plt.tight_layout()
plt.show()

plt.figure(figsize=(8, 5))
df['Marital_Status'].value_counts().plot(kind='bar', color='skyblue')
plt.title('Customer Count by Marital Status')
plt.xlabel('Marital Status')
plt.ylabel('Count')
plt.tight_layout()
plt.show()
```

## Task 3 — Normalize Numerical Features (Spending, Income)
```python
features = ['Income', 'MntWines', 'MntFruits', 'MntMeatProducts',
            'MntFishProducts', 'MntSweetProducts', 'MntGoldProds',
            'TotalSpending', 'Age']

df_features = df[features].copy()
print("Missing values in features:\n", df_features.isnull().sum())

scaler = StandardScaler()
df_scaled = scaler.fit_transform(df_features)
df_scaled = pd.DataFrame(df_scaled, columns=features)

print("\nScaled data (first 5 rows):")
print(df_scaled.head())
print("\nMean of each feature (should be ~0):")
print(df_scaled.mean().round(2))
print("\nStd of each feature (should be ~1):")
print(df_scaled.std().round(2))
```

## Task 4 — Choose Optimal Number of Clusters Using Elbow Method
```python
k_range = range(2, 11)
inertia_values = []

for k in k_range:
    kmeans = KMeans(n_clusters=k, random_state=42, n_init=10)
    kmeans.fit(df_scaled)
    inertia_values.append(kmeans.inertia_)

plt.figure(figsize=(8, 5))
plt.plot(k_range, inertia_values, marker='o', linewidth=2, color='red')
plt.title('Elbow Method — Finding Optimal K')
plt.xlabel('Number of Clusters (K)')
plt.ylabel('Inertia (Within-Cluster Sum of Squares)')
plt.xticks(k_range)
plt.grid(True)
plt.tight_layout()
plt.show()

for k, inertia in zip(k_range, inertia_values):
    print(f"K={k}: Inertia={inertia:.2f}")
```

## Task 5 — Apply K-Means Clustering
```python
optimal_k = 4
kmeans = KMeans(n_clusters=optimal_k, random_state=42, n_init=10)
kmeans_labels = kmeans.fit_predict(df_scaled)

df['KMeans_Cluster'] = kmeans_labels
print("Customers per cluster (K-Means):")
print(df['KMeans_Cluster'].value_counts().sort_index())

print("\nCluster Centers (scaled):")
centers_df = pd.DataFrame(kmeans.cluster_centers_, columns=features)
print(centers_df.round(2))

plt.figure(figsize=(7, 5))
df['KMeans_Cluster'].value_counts().sort_index().plot(kind='bar', color=['#FF6B6B', '#4ECDC4', '#45B7D1', '#96CEB4'])
plt.title('Number of Customers in Each K-Means Cluster')
plt.xlabel('Cluster')
plt.ylabel('Number of Customers')
plt.tight_layout()
plt.show()
```

## Task 6 — Apply Hierarchical Clustering and Compare
```python
sample_size = 200
df_sample = df_scaled.sample(n=sample_size, random_state=42)

linkage_matrix = linkage(df_sample, method='ward')

plt.figure(figsize=(14, 6))
dendrogram(linkage_matrix, truncate_mode='level', p=5, color_threshold=15)
plt.title('Hierarchical Clustering Dendrogram (Sample)')
plt.xlabel('Data Points')
plt.ylabel('Distance')
plt.tight_layout()
plt.show()

hierarchical = AgglomerativeClustering(n_clusters=4, linkage='ward')
hier_labels = hierarchical.fit_predict(df_scaled)

df['Hier_Cluster'] = hier_labels

print("Customers per cluster (Hierarchical):")
print(df['Hier_Cluster'].value_counts().sort_index())

print("\n--- Comparison ---")
print("\nK-Means cluster sizes:")
print(df['KMeans_Cluster'].value_counts().sort_index())

print("\nHierarchical cluster sizes:")
print(df['Hier_Cluster'].value_counts().sort_index())

print("\nCross-tabulation (K-Means vs Hierarchical):")
cross_tab = pd.crosstab(df['KMeans_Cluster'], df['Hier_Cluster'],
                         rownames=['K-Means'], colnames=['Hierarchical'])
print(cross_tab)

fig, axes = plt.subplots(1, 2, figsize=(14, 5))

df['KMeans_Cluster'].value_counts().sort_index().plot(kind='bar', ax=axes[0],
    color=['#FF6B6B', '#4ECDC4', '#45B7D1', '#96CEB4'])
axes[0].set_title('K-Means Cluster Sizes')
axes[0].set_xlabel('Cluster')
axes[0].set_ylabel('Count')

df['Hier_Cluster'].value_counts().sort_index().plot(kind='bar', ax=axes[1],
    color=['#FF6B6B', '#4ECDC4', '#45B7D1', '#96CEB4'])
axes[1].set_title('Hierarchical Cluster Sizes')
axes[1].set_xlabel('Cluster')
axes[1].set_ylabel('Count')

plt.tight_layout()
plt.show()
```

## Task 7 — Visualize Clusters Using PCA or t-SNE
```python
pca = PCA(n_components=2)
pca_result = pca.fit_transform(df_scaled)

df['PCA1'] = pca_result[:, 0]
df['PCA2'] = pca_result[:, 1]

plt.figure(figsize=(10, 6))
sns.scatterplot(x='PCA1', y='PCA2', hue='KMeans_Cluster', data=df,
                palette='Set2', alpha=0.6, s=50)
plt.title('K-Means Clusters — PCA Visualization')
plt.xlabel(f'PCA Component 1 ({pca.explained_variance_ratio_[0]*100:.1f}% variance)')
plt.ylabel(f'PCA Component 2 ({pca.explained_variance_ratio_[1]*100:.1f}% variance)')
plt.legend(title='Cluster')
plt.tight_layout()
plt.show()

print(f"PCA explained variance: {sum(pca.explained_variance_ratio_)*100:.1f}%")

tsne = TSNE(n_components=2, random_state=42, perplexity=30)
tsne_result = tsne.fit_transform(df_scaled)

df['TSNE1'] = tsne_result[:, 0]
df['TSNE2'] = tsne_result[:, 1]

plt.figure(figsize=(10, 6))
sns.scatterplot(x='TSNE1', y='TSNE2', hue='KMeans_Cluster', data=df,
                palette='Set2', alpha=0.6, s=50)
plt.title('K-Means Clusters — t-SNE Visualization')
plt.xlabel('t-SNE Component 1')
plt.ylabel('t-SNE Component 2')
plt.legend(title='Cluster')
plt.tight_layout()
plt.show()

plt.figure(figsize=(10, 6))
sns.scatterplot(x='TSNE1', y='TSNE2', hue='Hier_Cluster', data=df,
                palette='Set1', alpha=0.6, s=50)
plt.title('Hierarchical Clusters — t-SNE Visualization')
plt.xlabel('t-SNE Component 1')
plt.ylabel('t-SNE Component 2')
plt.legend(title='Cluster')
plt.tight_layout()
plt.show()
```

## Task 8 — Profile Each Cluster (Age, Income, Loyalty)
```python
df['TotalPurchases'] = (df['NumDealsPurchases'] + df['NumWebPurchases']
                        + df['NumCatalogPurchases'] + df['NumStorePurchases'])

df['Dt_Customer'] = pd.to_datetime(df['Dt_Customer'])
df['Customer_Days'] = (pd.Timestamp('2024-01-01') - df['Dt_Customer']).dt.days

profile_cols = ['Age', 'Income', 'TotalSpending', 'TotalPurchases',
                'Customer_Days', 'MntWines', 'MntMeatProducts',
                'MntFruits', 'MntSweetProducts', 'MntGoldProds']

cluster_profile = df.groupby('KMeans_Cluster')[profile_cols].mean().round(1)
print("=== Cluster Profiles (K-Means) ===\n")
print(cluster_profile.T)

plt.figure(figsize=(8, 5))
df.groupby('KMeans_Cluster')['Income'].mean().plot(kind='bar',
    color=['#FF6B6B', '#4ECDC4', '#45B7D1', '#96CEB4'])
plt.title('Average Income by Cluster')
plt.xlabel('Cluster')
plt.ylabel('Average Income')
plt.tight_layout()
plt.show()

plt.figure(figsize=(8, 5))
df.groupby('KMeans_Cluster')['Age'].mean().plot(kind='bar',
    color=['#FF6B6B', '#4ECDC4', '#45B7D1', '#96CEB4'])
plt.title('Average Age by Cluster')
plt.xlabel('Cluster')
plt.ylabel('Average Age')
plt.tight_layout()
plt.show()

plt.figure(figsize=(8, 5))
df.groupby('KMeans_Cluster')['TotalSpending'].mean().plot(kind='bar',
    color=['#FF6B6B', '#4ECDC4', '#45B7D1', '#96CEB4'])
plt.title('Average Total Spending by Cluster')
plt.xlabel('Cluster')
plt.ylabel('Average Spending')
plt.tight_layout()
plt.show()

plt.figure(figsize=(8, 5))
df.groupby('KMeans_Cluster')['Customer_Days'].mean().plot(kind='bar',
    color=['#FF6B6B', '#4ECDC4', '#45B7D1', '#96CEB4'])
plt.title('Average Customer Tenure (Days) by Cluster')
plt.xlabel('Cluster')
plt.ylabel('Days as Customer')
plt.tight_layout()
plt.show()

spending_by_cluster = df.groupby('KMeans_Cluster')[spending_cols].mean()
plt.figure(figsize=(10, 5))
sns.heatmap(spending_by_cluster, annot=True, fmt='.0f', cmap='YlOrRd')
plt.title('Average Spending by Category per Cluster')
plt.xlabel('Product Category')
plt.ylabel('Cluster')
plt.tight_layout()
plt.show()
```

## Task 9 — Label Original Dataset with Cluster IDs
```python
print("Columns with cluster labels:")
print([col for col in df.columns if 'Cluster' in col])

print("\nSample of labeled dataset:")
print(df[['ID', 'Age', 'Income', 'TotalSpending', 'KMeans_Cluster', 'Hier_Cluster']].head(10))

df.to_csv("Customer_Segmented.csv", index=False)
print("\nLabeled dataset saved as 'Customer_Segmented.csv'")

print("\n--- Final Cluster Assignment Summary ---")
for cluster_id in sorted(df['KMeans_Cluster'].unique()):
    count = (df['KMeans_Cluster'] == cluster_id).sum()
    pct = count / len(df) * 100
    print(f"Cluster {cluster_id}: {count} customers ({pct:.1f}%)")
```

## Task 10 — Recommend Marketing Strategy per Cluster
```python
print("=== Cluster Profiles Summary ===\n")
summary = df.groupby('KMeans_Cluster')[['Age', 'Income', 'TotalSpending',
                                         'TotalPurchases', 'Customer_Days']].mean().round(1)
print(summary)
print()

strategies = {
    0: {
        "Name": "Budget-Conscious Shoppers",
        "Profile": "Lower income, low spending, fewer purchases",
        "Strategy": [
            "Offer discount coupons and deal-of-the-day promotions",
            "Promote budget-friendly product bundles",
            "Use email campaigns with special offers",
            "Focus on value-for-money messaging",
        ]
    },
    1: {
        "Name": "High-Value Premium Customers",
        "Profile": "High income, high spending, frequent purchases",
        "Strategy": [
            "Offer exclusive loyalty rewards and VIP programs",
            "Recommend premium and luxury products",
            "Provide early access to new products",
            "Personalized recommendations based on purchase history",
        ]
    },
    2: {
        "Name": "Average Moderate Spenders",
        "Profile": "Medium income, moderate spending",
        "Strategy": [
            "Cross-sell and upsell related products",
            "Seasonal promotions and festive offers",
            "Introduce mid-range product lines",
            "Engage through social media and content marketing",
        ]
    },
    3: {
        "Name": "Occasional / At-Risk Customers",
        "Profile": "Mixed income, low engagement, infrequent purchases",
        "Strategy": [
            "Send re-engagement emails with special comeback offers",
            "Provide free shipping or trial offers to encourage purchases",
            "Run win-back campaigns with personalized discounts",
            "Survey to understand why they stopped buying",
        ]
    }
}

print("=" * 60)
print("   MARKETING STRATEGY RECOMMENDATIONS PER CLUSTER")
print("=" * 60)

for cluster_id, info in strategies.items():
    print(f"\n--- Cluster {cluster_id}: {info['Name']} ---")
    print(f"    Profile: {info['Profile']}")
    print("    Recommended Strategies:")
    for i, strategy in enumerate(info['Strategy'], 1):
        print(f"      {i}. {strategy}")

print("\n" + "=" * 60)

fig, ax = plt.subplots(figsize=(10, 6))
summary_plot = df.groupby('KMeans_Cluster')[['Income', 'TotalSpending']].mean()
summary_plot.plot(kind='bar', ax=ax, color=['#4ECDC4', '#FF6B6B'])
plt.title('Cluster Comparison — Income vs Spending')
plt.xlabel('Cluster')
plt.ylabel('Amount')
plt.legend(['Average Income', 'Average Spending'])
plt.tight_layout()
plt.show()
```
