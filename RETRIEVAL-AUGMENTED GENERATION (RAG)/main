### B4. Unit Test for Output Consistency Across Temperatures

This script provides a complete `unittest` test suite that verifies that structured prompts produce consistent output formats across different temperature conditions ($0.2, 0.7, 1.2$). It leverages a high-fidelity simulated LLM function to demonstrate the principles of formatting resilience.

```python

# B4: Unit Test for Output Consistency Across Temperatures

import unittest
import json

# --- Simulated LLM Client Engine ---
def mock_llm_generate(prompt: str, temperature: float) -> str:
    """
    Simulates the stochastic generation behavior of a Large Language Model.
    
    - If the prompt is poorly structured, format structure decays as temperature increases.
    - If the prompt is highly structured (contains '[ROLE]' and '[CONSTRAINTS]'),
      the schema is strictly followed regardless of the temperature.
    """
    has_structure = "[ROLE]" in prompt and "[CONSTRAINTS]" in prompt
    
    data_payload = {
        "status": "success",
        "action_items": ["Optimize query indices", "Resolve sequential scans"]
    }
    
    if has_structure:
        # Structured prompts focus attention matrices to strictly adhere to the formatting boundary.
        # Thus, even at temperature 1.2, it returns clean, valid, parseable JSON.
        return json.dumps(data_payload)
    else:
        # Poor prompts lead to structural degradation under higher stochastic sampling (temperature).
        if temperature <= 0.2:
            return json.dumps(data_payload)
        elif temperature == 0.7:
            return f"Here is the result you requested:\n{json.dumps(data_payload)}"
        else:
            # High temperature (1.2) causes complete format structure collapse
            return "Sure! I looked over your query logs. You definitely need to optimize the database. Let me know!"


# --- Unit Test Suite ---
class TestPromptConsistency(unittest.TestCase):
    """
    Verifies that structured, rewritten prompts produce consistent,
    parseable formats across various LLM temperature profiles.
    """

    def setUp(self):
        self.temperatures = [0.2, 0.7, 1.2]
        
        self.poor_prompt = "Analyze the database performance metrics and return a list of actions."
        
        self.structured_prompt = """
        [ROLE]
        You are a principal systems administrator.
        
        [CONTEXT]
        Database metrics reveal high CPU usage and slow queries due to lack of indexing.
        
        [INSTRUCTION]
        Identify key action items to optimize performance.
        
        [CONSTRAINTS]
        You must respond ONLY with a raw JSON block containing keys: 'status' and 'action_items'.
        Do not write any introductory or concluding text.
        """

    def test_structured_prompt_format_consistency(self):
        """
        Asserts that the structured prompt produces valid, parseable JSON
        across all test temperatures (0.2, 0.7, 1.2).
        """
        for temp in self.temperatures:
            response = mock_llm_generate(self.structured_prompt, temperature=temp)
            
            try:
                parsed_data = json.loads(response)
                self.assertIn("status", parsed_data)
                self.assertIn("action_items", parsed_data)
                self.assertEqual(parsed_data["status"], "success")
            except json.JSONDecodeError:
                self.fail(f"Structured prompt failed parsing at temperature {temp}. Output: '{response}'")

    def test_poor_prompt_format_failure(self):
        """
        Demonstrates that poor prompts fail format parsing rules
        as the temperature (stochastic variance) increases.
        """
        high_temp_response = mock_llm_generate(self.poor_prompt, temperature=1.2)
        
        with self.assertRaises(json.JSONDecodeError):
            json.loads(high_temp_response)


if __name__ == "__main__":
    unittest.main()
```

