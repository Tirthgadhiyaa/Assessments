### B2. Prompt Auditor Function

This script implements a "Prompt Auditor" function that checks case-insensitively for the presence of the core structural components and keywords, scores prompt health, and yields constructive suggestions.

```python

# B2: Prompt Auditor Function

import re
from typing import Dict, Any

def audit_prompt(prompt_string: str) -> Dict[str, Any]:
    """
    Audits a given prompt string for structural components and keywords.
    Returns a comprehensive report with a metric score and actionable advice.
    """
    if not prompt_string or not isinstance(prompt_string, str):
        return {
            "score": 0,
            "components_found": {},
            "recommendations": ["Prompt must be a non-empty string."],
            "is_structured": False
        }
        
    # Define structured components and their associated indicator pattern lists
    components = {
        "Role / Persona": {
            "patterns": [r"\brole\b", r"\bpersona\b", r"\bact as\b", r"\byou are a\b"],
            "weight": 25
        },
        "Context / Background": {
            "patterns": [r"\bcontext\b", r"\bbackground\b", r"\bsituation\b", r"\bdata\b", r"\bmetadata\b"],
            "weight": 25
        },
        "Instruction / Task": {
            "patterns": [r"\binstruction\b", r"\btask\b", r"\bdo the following\b", r"\bperform\b", r"\bexecute\b", r"\bsummarize\b", r"\bextract\b"],
            "weight": 25
        },
        "Example / Output Format": {
            "patterns": [r"\bexample\b", r"\bformat\b", r"\bconstraint\b", r"\bjson\b", r"\bxml\b", r"\btemplate\b", r"\bfew-shot\b"],
            "weight": 25
        }
    }
    
    score = 0
    components_found = {}
    recommendations = []
    
    # Check for presence of each component
    for component_name, config in components.items():
        found = False
        for pattern in config["patterns"]:
            if re.search(pattern, prompt_string, re.IGNORECASE):
                found = True
                break
        
        components_found[component_name] = found
        if found:
            score += config["weight"]
        else:
            recommendations.append(
                f"Missing '{component_name}'. Add a dedicated section (e.g., '[{component_name.split(' / ')[0].upper()}]')."
            )
            
    # Audit delimitation boundary indicators
    has_delimiters = bool(re.search(r"\[[A-Z_]+\]|\<[a-z_]+\>", prompt_string))
    if not has_delimiters:
        score = max(0, score - 10)  # Deduct points for poor layout hygiene
        recommendations.append(
            "Add clear structural delimiters (e.g. square brackets '[ROLE]' or XML tags) to isolate instructions."
        )
    else:
        score = min(100, score + 10)  # Reward visual structure

    is_structured = score >= 80

    return {
        "score": score,
        "components_found": components_found,
        "recommendations": recommendations if recommendations else ["Excellent prompt hygiene! Meets enterprise-grade quality standards."],
        "is_structured": is_structured
    }


# --- Demonstration ---
if __name__ == "__main__":
    poor = "Summarize customer complaints in the spreadsheet."
    
    structured = """
    [ROLE]
    You are a professional customer experience analyst.
    
    [CONTEXT]
    Customer Logs: "My delivery took two weeks." "The item was cracked upon opening."
    
    [INSTRUCTION]
    Perform the task of classifying complaints into distinct groups.
    
    [OUTPUT FORMAT / EXAMPLE]
    Respond strictly in JSON format. Example:
    {
      "category": "shipping_delay",
      "count": 1
    }
    """
    
    import json
    print("--- Poor Prompt Audit ---")
    print(json.dumps(audit_prompt(poor), indent=2))
    
    print("\n--- Structured Prompt Audit ---")
    print(json.dumps(audit_prompt(structured), indent=2))
```

